---
import ThemeSwitcherIcon from './ThemeSwitcherIcon';

interface Props {
  small?: boolean;
  group?: string;
}

const { small = false, group = 'site' } = Astro.props;
const iconSize = small ? 14 : 16;

const options = [
  { value: 'system', label: 'System theme' },
  { value: 'light', label: 'Light theme' },
  { value: 'dark', label: 'Dark theme' },
] as const;
---

<fieldset
  class:list={['theme-switcher', { 'theme-switcher-small': small }]}
  data-theme-switcher
>
  <legend class="theme-switcher-legend">Select a display theme:</legend>
  {
    options.map((option) => {
      const inputId = `theme-switch-${option.value}-${group}`;
      return (
        <span class="theme-switcher-item">
          <input
            type="radio"
            class="theme-switcher-input"
            id={inputId}
            name={`theme-switch-${group}`}
            value={option.value}
            data-theme-value={option.value}
            aria-label={option.label}
          />
          <label class="theme-switcher-option" for={inputId}>
            <span class="theme-switcher-sr-only">{option.value}</span>
            <span class="theme-switcher-icon" aria-hidden="true">
              <ThemeSwitcherIcon value={option.value} size={iconSize} />
            </span>
          </label>
        </span>
      );
    })
  }
</fieldset>

<style>
  .theme-switcher {
    display: inline-flex;
    align-items: stretch;
    margin: 0;
    padding: 0;
    border: 0;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-border);
    background: transparent;
    isolation: isolate;
    height: 2rem;
    width: fit-content;
  }

  .theme-switcher-small {
    height: 1.5rem;
  }

  .theme-switcher-legend {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .theme-switcher-item {
    display: inline-flex;
    height: 100%;
    position: relative;
  }

  .theme-switcher-input {
    position: absolute;
    appearance: none;
    margin: 0;
    padding: 0;
    outline: none;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .theme-switcher-option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    margin: 0;
    border-radius: var(--radius-pill);
    color: var(--ds-gray-700);
    cursor: pointer;
    transition:
      color var(--motion-fast),
      background var(--motion-fast),
      box-shadow var(--motion-fast);
  }

  .theme-switcher-small .theme-switcher-option {
    width: 1.5rem;
    height: 1.5rem;
  }

  .theme-switcher-option:hover {
    color: var(--ds-gray-1000);
  }

  .theme-switcher-input:checked + .theme-switcher-option {
    color: var(--ds-gray-1000);
    background: var(--ds-background-100);
    box-shadow: var(--shadow-switcher-active);
  }

  .theme-switcher-input:focus-visible + .theme-switcher-option {
    color: var(--ds-gray-1000);
    box-shadow:
      0 0 0 2px var(--ds-background-100),
      0 0 0 4px var(--color-focus);
  }

  .theme-switcher-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .theme-switcher-icon {
    display: inline-flex;
    line-height: 0;
    width: 1rem;
    height: 1rem;
  }

  .theme-switcher-icon svg {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const STORAGE_KEY = 'portfolio-theme';

  type ThemePreference = 'light' | 'dark' | 'system';

  let listenersBound = false;

  function getStoredTheme(): ThemePreference {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'light' || stored === 'dark' || stored === 'system') return stored;
    return 'system';
  }

  function applyTheme(preference: ThemePreference) {
    document.documentElement.dataset.theme = preference;
    document
      .querySelectorAll('[data-theme-switcher] input[data-theme-value]')
      .forEach((input) => {
        const value = input.getAttribute('data-theme-value');
        (input as HTMLInputElement).checked = value === preference;
      });
  }

  function initThemeSwitcher() {
    applyTheme(getStoredTheme());

    if (listenersBound) return;
    listenersBound = true;

    document.addEventListener('change', (event) => {
      const target = event.target as HTMLInputElement;
      if (!target.matches('[data-theme-switcher] input[data-theme-value]')) return;
      const value = target.value as ThemePreference;
      localStorage.setItem(STORAGE_KEY, value);
      applyTheme(value);
    });

    window
      .matchMedia('(prefers-color-scheme: dark)')
      .addEventListener('change', () => {
        if (getStoredTheme() === 'system') applyTheme('system');
      });
  }

  initThemeSwitcher();
  document.addEventListener('astro:page-load', initThemeSwitcher);
</script>
