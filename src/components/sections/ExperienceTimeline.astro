---
import EmployerLogo from '../EmployerLogo.astro';
import type { ResumeExperience } from '../../lib/content/resume';

interface Props {
  entries: readonly ResumeExperience[];
}

const { entries } = Astro.props;
---

<ol class="experience-timeline" aria-label="Work experience">
  {
    entries.map((entry, index) => (
      <li class="timeline-item">
        <div class="timeline-opposite">
          <time class="timeline-period">{entry.period}</time>
        </div>
        <div class="timeline-separator" aria-hidden="true">
          <span class="timeline-dot" />
          {index < entries.length - 1 && <span class="timeline-connector" />}
        </div>
        <div class="timeline-content">
          {entry.logo && (
            <div class="timeline-logo">
              <EmployerLogo
                srcLight={entry.logo.srcLight}
                srcDark={entry.logo.srcDark}
                alt={entry.logo.alt}
                width={entry.logo.width}
                height={entry.logo.height}
              />
            </div>
          )}
          <h3 class="timeline-title">
            {entry.title} · {entry.organization}
          </h3>
          {entry.scope && <p class="timeline-scope">{entry.scope}</p>}
          <ul class="timeline-highlights">
            {entry.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .experience-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: minmax(6.5rem, 9rem) 1.5rem 1fr;
    gap: 0 var(--space-md);
    align-items: start;
    padding-left: 0;
    border-left: none;
  }

  .timeline-opposite {
    padding-top: 0.125rem;
    text-align: right;
  }

  .timeline-period {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    line-height: 1.4;
    white-space: nowrap;
  }

  .timeline-separator {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100%;
    padding-top: 0.375rem;
  }

  .timeline-dot {
    flex-shrink: 0;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-soft);
  }

  .timeline-connector {
    flex: 1;
    width: 2px;
    min-height: 1.5rem;
    margin-top: var(--space-xs);
    background: var(--color-border);
  }

  .timeline-content {
    padding-bottom: var(--space-xl);
  }

  .timeline-logo {
    margin-bottom: var(--space-sm);
  }

  .timeline-item:last-child .timeline-content {
    padding-bottom: 0;
  }

  .timeline-title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .timeline-scope {
    margin: calc(-1 * var(--space-xs)) 0 var(--space-sm);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .timeline-highlights {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .timeline-highlights li + li {
    margin-top: var(--space-xs);
  }

  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 1.5rem 1fr;
      grid-template-rows: auto auto;
    }

    .timeline-opposite {
      grid-column: 2;
      grid-row: 1;
      text-align: left;
      padding-top: 0;
      margin-bottom: var(--space-xs);
    }

    .timeline-separator {
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    .timeline-content {
      grid-column: 2;
      grid-row: 2;
    }

    .timeline-period {
      font-size: 0.875rem;
    }
  }

  @media print {
    .timeline-dot {
      background: black;
      box-shadow: none;
    }

    .timeline-connector {
      background: #ccc;
    }

    .timeline-title {
      color: black;
    }
  }
</style>
