---
import Tag from './Tag.astro';

interface Props {
  title: string;
  excerpt: string;
  href: string;
  tags?: string[];
  thumbnail?: string | null;
  thumbnailAlt?: string | null;
  meta?: string;
  highlightTags?: boolean;
}

const {
  title,
  excerpt,
  href,
  tags = [],
  thumbnail,
  thumbnailAlt,
  meta,
  highlightTags = false,
} = Astro.props;
---

<article class="card">
  {
    thumbnail ? (
      <a class="card-media" href={href} tabindex="-1" aria-hidden="true">
        <img src={thumbnail} alt={thumbnailAlt ?? ''} loading="lazy" />
      </a>
    ) : (
      <a class="card-media card-media-fallback" href={href} tabindex="-1" aria-hidden="true">
        <span>{title.slice(0, 1)}</span>
      </a>
    )
  }
  <div class="card-body">
    {meta && <p class="card-meta">{meta}</p>}
    <h3><a href={href}>{title}</a></h3>
    <p>{excerpt}</p>
    {
      tags.length > 0 && (
        <div class="tag-list">
          {tags.slice(0, 4).map((tag) => (
            <Tag label={tag.replace(/-/g, ' ')} variant={highlightTags ? 'accent' : 'default'} />
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-base);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--motion-fast),
      box-shadow var(--motion-medium);
  }

  .card:hover {
    border-color: color-mix(in srgb, var(--glow-purple) 35%, var(--glow-blue) 65%);
    box-shadow: var(--shadow-card-glow), var(--shadow-raised);
  }

  @media (prefers-reduced-motion: no-preference) {
    .card:hover {
      transform: translateY(-2px);
    }
  }

  .card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--ds-gray-200);
    text-decoration: none;
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-media-fallback {
    display: grid;
    place-items: center;
    font-family: var(--font-sans);
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--color-eyebrow);
  }

  .card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .card-meta {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .card-body h3 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .card-body h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-body h3 a:hover {
    color: var(--color-accent);
  }

  .card-body p {
    margin: 0;
    color: var(--color-text-muted);
  }
</style>
