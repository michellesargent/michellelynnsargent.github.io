---
interface Props {
  caption?: string;
  class?: string;
}

const { caption, class: className } = Astro.props;
---

<div class:list={['geist-table-root', className]}>
  <table class="geist-table">
    {caption && <caption class="geist-table-caption">{caption}</caption>}
    <slot />
  </table>
</div>

<style>
  .geist-table-root {
    width: 100%;
    overflow-x: auto;
  }

  .geist-table {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .geist-table-caption {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .geist-table :global(thead th) {
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: left;
    color: var(--color-eyebrow);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .geist-table :global(tbody td) {
    padding: var(--space-md);
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .geist-table :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .geist-table :global(.geist-table-primary) {
    color: var(--color-text);
    font-weight: 500;
  }

  @media print {
    .geist-table :global(thead th),
    .geist-table :global(tbody td) {
      color: black;
      border-color: #ccc;
    }
  }
</style>
